<div style="height: 80px;"></div>

<section class="section fade-in" style="min-height: 80vh; display: flex; align-items: center;">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-5">

        <!-- Flash Messages -->
        <% if (typeof messages !== 'undefined' && messages.error && messages.error.length > 0) { %>
          <div class="error-box mb-4"><i class="fas fa-exclamation-triangle me-2"></i><%= messages.error[0] %></div>
        <% } %>
        <% if (typeof messages !== 'undefined' && messages.success && messages.success.length > 0) { %>
          <div class="success-box mb-4"><i class="fas fa-check-circle me-2"></i><%= messages.success[0] %></div>
        <% } %>

        <div class="form-box" style="text-align: left;">
          <div class="text-center mb-4">
            <i class="fas fa-shield-halved" style="font-size: 2.5rem; color: #00b4ff;"></i>
            <h3 class="mt-2" style="font-weight: 800;">Welcome Back</h3>
            <p style="color: #7a92b0; font-size: 0.9rem;">Log in to your SecureNet account</p>
          </div>

          <form action="/auth/login" method="POST">
            <div class="mb-3">
              <label style="color: #a8c4e0; font-size: 0.86rem; font-weight: 500;">Email Address</label>
              <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
            </div>
            <div class="mb-4">
              <label style="color: #a8c4e0; font-size: 0.86rem; font-weight: 500;">Password</label>
              <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="btn btn-main w-100 py-2 fw-bold">
              <i class="fas fa-sign-in-alt me-2"></i> Login
            </button>
          </form>

          <p class="text-center mt-4" style="color: #7a92b0; font-size: 0.9rem;">
            Don't have an account? <a href="/auth/register" style="color: #00b4ff;">Create one here</a>
          </p>
        </div>

      </div>
    </div>
  </div>
</section>
