<div class="mb-4">
  <a href="/admin/products" class="text-decoration-none text-muted"><i class="fas fa-arrow-left"></i> Back to Products</a>
  <h2 style="font-weight: 700; color: #0a1628; margin-top: 10px;">Edit Product: <%= product.name %></h2>
</div>

<div class="card-box" style="max-width: 800px;">
  <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">
    
    <div class="row g-3">
      <!-- Name -->
      <div class="col-md-12 mb-3">
        <label class="form-label fw-bold">Product Name <span class="text-danger">*</span></label>
        <input type="text" name="name" class="form-control" value="<%= product.name %>" required>
      </div>

      <!-- Category -->
      <div class="col-md-6 mb-3">
        <label class="form-label fw-bold">Category <span class="text-danger">*</span></label>
        <select name="category" class="form-select" required>
          <option value="">Select a category</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat._id %>" <%= String(product.category) === String(cat._id) ? 'selected' : '' %>>
              <%= cat.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Price -->
      <div class="col-md-6 mb-3">
        <label class="form-label fw-bold">Price ($) <span class="text-danger">*</span></label>
        <input type="number" name="price" class="form-control" min="0" step="0.01" value="<%= product.price %>" required>
      </div>

      <!-- Stock -->
      <div class="col-md-6 mb-3">
        <label class="form-label fw-bold">Stock Quantity <span class="text-danger">*</span></label>
        <input type="number" name="stock" class="form-control" min="0" value="<%= product.stock %>" required>
      </div>

      <!-- Rating -->
      <div class="col-md-6 mb-3">
        <label class="form-label fw-bold">Rating (0-5)</label>
        <input type="number" name="rating" class="form-control" min="0" max="5" step="0.1" value="<%= product.rating %>">
      </div>

      <!-- Current Image Display -->
      <div class="col-12 mb-2">
        <label class="form-label fw-bold">Current Image</label><br>
        <img src="<%= product.image %>" alt="<%= product.name %>" style="max-height: 150px; background: #f8f9fa; padding: 10px; border-radius: 8px;">
      </div>

      <!-- Image Upload (Replacement) -->
      <div class="col-12 mb-3">
        <label class="form-label fw-bold">Replace Image (Optional)</label>
        <input type="file" name="image" class="form-control" accept="image/*">
        <small class="text-muted">Leave blank to keep the current image. Max size: 5MB.</small>
      </div>

      <!-- Description -->
      <div class="col-12 mb-4">
        <label class="form-label fw-bold">Product Description</label>
        <textarea name="description" class="form-control" rows="4"><%= product.description %></textarea>
      </div>

      <!-- Submit -->
      <div class="col-12 text-end">
        <a href="/admin/products" class="btn btn-light me-2">Cancel</a>
        <button type="submit" class="btn btn-primary" style="background-color: #1a73e8; border: none;">
          <i class="fas fa-save"></i> Update Product
        </button>
      </div>
    </div>

  </form>
</div>
