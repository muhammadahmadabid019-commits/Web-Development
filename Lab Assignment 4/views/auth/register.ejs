<style>
  .auth-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(0,212,255,0.15);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 460px;
    backdrop-filter: blur(12px);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 40px rgba(0,212,255,0.05);
  }
  .auth-logo { text-align: center; margin-bottom: 1.5rem; }
  .auth-logo i { color: #00d4ff; font-size: 2.4rem; }
  .auth-logo h2 { color: #fff; font-weight: 700; font-size: 1.5rem; margin: 0.4rem 0 0; }
  .auth-logo p { color: #7a92b0; font-size: 0.85rem; margin: 0; }
  .form-label { color: #c0d0e0; font-size: 0.85rem; font-weight: 500; margin-bottom: 0.4rem; }
  .form-control {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(0,212,255,0.2);
    border-radius: 10px;
    color: #fff;
    padding: 0.65rem 1rem;
    font-size: 0.9rem;
    transition: border-color 0.25s, box-shadow 0.25s;
  }
  .form-control:focus {
    background: rgba(255,255,255,0.1);
    border-color: #00d4ff;
    box-shadow: 0 0 0 3px rgba(0,212,255,0.15);
    color: #fff;
    outline: none;
  }
  .form-control::placeholder { color: #4a6a8a; }
  .btn-auth {
    width: 100%;
    background: linear-gradient(135deg, #00d4ff, #0099cc);
    border: none;
    border-radius: 10px;
    padding: 0.75rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    margin-top: 0.5rem;
  }
  .btn-auth:hover { opacity: 0.9; transform: translateY(-1px); }
  .alert-danger-custom {
    background: rgba(220,53,69,0.15);
    border: 1px solid rgba(220,53,69,0.4);
    border-radius: 10px;
    color: #ff6b6b;
    padding: 0.7rem 1rem;
    font-size: 0.85rem;
    margin-bottom: 1rem;
  }
  .auth-footer { text-align: center; margin-top: 1.2rem; color: #7a92b0; font-size: 0.85rem; }
  .auth-footer a { color: #00d4ff; text-decoration: none; font-weight: 600; }
  .auth-footer a:hover { text-decoration: underline; }
  .input-icon-wrap { position: relative; }
  .input-icon-wrap .form-control { padding-left: 2.6rem; }
  .input-icon-wrap i {
    position: absolute; left: 0.85rem; top: 50%;
    transform: translateY(-50%); color: #4a6a8a; font-size: 0.85rem;
  }
  .divider { border-color: rgba(0,212,255,0.1); margin: 1.2rem 0; }
</style>

<div class="auth-card">
  <div class="auth-logo">
    <i class="fas fa-shield-halved"></i>
    <h2>SecureNet Solutions</h2>
    <p>Create your account</p>
  </div>

  <% if (error) { %>
    <div class="alert-danger-custom">
      <i class="fas fa-exclamation-circle me-1"></i> <%= error %>
    </div>
  <% } %>

  <form action="/auth/register" method="POST" novalidate>
    <div class="mb-3">
      <label class="form-label" for="name">Full Name</label>
      <div class="input-icon-wrap">
        <i class="fas fa-user"></i>
        <input type="text" class="form-control" id="name" name="name"
          placeholder="e.g. Ahmad Ali" required />
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label" for="email">Email Address</label>
      <div class="input-icon-wrap">
        <i class="fas fa-envelope"></i>
        <input type="email" class="form-control" id="email" name="email"
          placeholder="you@example.com" required />
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label" for="password">Password</label>
      <div class="input-icon-wrap">
        <i class="fas fa-lock"></i>
        <input type="password" class="form-control" id="password" name="password"
          placeholder="Min 6 characters" required />
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label" for="confirmPassword">Confirm Password</label>
      <div class="input-icon-wrap">
        <i class="fas fa-lock"></i>
        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword"
          placeholder="Repeat your password" required />
      </div>
    </div>

    <button type="submit" class="btn-auth">
      <i class="fas fa-user-plus me-2"></i>Create Account
    </button>
  </form>

  <hr class="divider" />
  <div class="auth-footer">
    Already have an account? <a href="/auth/login">Sign In</a>
  </div>
</div>
