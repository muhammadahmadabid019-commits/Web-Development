<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'SecureNet Solutions' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick-theme.min.css"/>
</head>
<body>

  <nav class="navbar navbar-expand-lg fixed-top" id="mainNavbar">
    <div class="container">
      <a class="navbar-brand" href="/">
        <i class="fas fa-shield-halved"></i>
        <span>SecureNet</span> Solutions
      </a>

      <button class="custom-hamburger" id="hamburgerBtn" aria-label="Toggle Menu">
        <span class="hbar"></span>
        <span class="hbar"></span>
        <span class="hbar"></span>
      </button>

      <ul class="custom-nav-links" id="navLinks">
        <li><a class="nav-link" href="/">Home</a></li>
        <li><a class="nav-link" href="/#services">Services</a></li>
        <li><a class="nav-link" href="/products">Products</a></li>
        <li><a class="nav-link" href="/#contact">Contact</a></li>

        <!-- Cart Icon -->
        <li>
          <a class="nav-link position-relative" href="/cart" id="cartIcon">
            <i class="fas fa-shopping-cart"></i>
            <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem;">
                <%= cartCount %>
              </span>
            <% } %>
          </a>
        </li>

        <!-- Dynamic Auth Links -->
        <% if (currentUser && currentUser.id) { %>
          <% if (currentUser.role === 'admin') { %>
            <li><a class="nav-link" href="/admin/products" style="color: #00ffc6 !important;"><i class="fas fa-cogs"></i> Admin</a></li>
          <% } %>
          <li>
            <form action="/auth/logout" method="POST" class="m-0 p-0" style="display:inline;">
              <button type="submit" class="btn-cart" style="border-radius: 50px; padding: 7px 18px; font-size: 0.83rem;">
                <i class="fas fa-sign-out-alt"></i> Logout
              </button>
            </form>
          </li>
        <% } else { %>
          <li><a class="nav-link" href="/auth/login"><i class="fas fa-sign-in-alt"></i> Login</a></li>
          <li><a class="btn-cart" href="/auth/register" style="border-radius: 50px; padding: 7px 18px; font-size: 0.83rem; text-decoration:none;"><i class="fas fa-user-plus"></i> Register</a></li>
        <% } %>
      </ul>
    </div>
  </nav>

  <!-- Flash Messages (global, shown just below navbar) -->
  <div style="padding-top: 80px;">
    <% if (typeof messages !== 'undefined' && messages.success && messages.success.length > 0) { %>
      <div class="container mt-3">
        <div class="success-box"><i class="fas fa-check-circle me-2"></i><%= messages.success[0] %></div>
      </div>
    <% } %>
    <% if (typeof messages !== 'undefined' && messages.error && messages.error.length > 0) { %>
      <div class="container mt-3">
        <div class="error-box"><i class="fas fa-exclamation-triangle me-2"></i><%= messages.error[0] %></div>
      </div>
    <% } %>
  </div>

  <%- body %>

  <footer class="footer">
    <div class="container">
      <div class="row g-4">

        <div class="col-lg-4">
          <div class="footer-brand"><i class="fas fa-shield-halved"></i> <span>SecureNet</span> Solutions</div>
          <p style="color:#7a92b0; font-size:0.9rem; margin:12px 0 20px;">Pakistan's trusted provider of CCTV, networking and tech support since 2015.</p>
          <div class="socials">
            <a href="#"><i class="fab fa-facebook-f"></i></a>
            <a href="#"><i class="fab fa-instagram"></i></a>
            <a href="#"><i class="fab fa-linkedin-in"></i></a>
            <a href="#"><i class="fab fa-whatsapp"></i></a>
          </div>
        </div>

        <div class="col-lg-2 col-md-6">
          <h6 class="footer-head">Quick Links</h6>
          <ul class="footer-links">
            <li><a href="/">Home</a></li>
            <li><a href="/#services">Services</a></li>
            <li><a href="/products">Products</a></li>
            <li><a href="/#contact">Contact</a></li>
          </ul>
        </div>

        <div class="col-lg-3 col-md-6">
          <h6 class="footer-head">Services</h6>
          <ul class="footer-links">
            <li><a href="/#services">CCTV Installation</a></li>
            <li><a href="/#services">Network Setup</a></li>
            <li><a href="/#services">Tech Support</a></li>
            <li><a href="/products">Shop Products</a></li>
          </ul>
        </div>

        <div class="col-lg-3">
          <h6 class="footer-head">Contact Info</h6>
          <ul class="footer-contact">
            <li><i class="fas fa-map-marker-alt"></i> Blue Area, Islamabad</li>
            <li><i class="fas fa-phone"></i> +92-300-1234567</li>
            <li><i class="fas fa-envelope"></i> info@securenetsolutions.pk</li>
            <li><i class="fas fa-clock"></i> Mon–Sat: 9AM – 7PM</li>
          </ul>
        </div>

      </div>

      <div class="footer-bottom">
        <p>&copy; 2026 SecureNet Solutions. All Rights Reserved.</p>
        <p>Made with <i class="fas fa-heart" style="color:red;"></i> in Pakistan</p>
      </div>
    </div>
  </footer>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/slick-carousel/1.8.1/slick.min.js"></script>
  <script src="/script.js"></script>
</body>
</html>
